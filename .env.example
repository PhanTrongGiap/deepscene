# DeepScene environment

# ============================================================
# Provider keys
# ============================================================
# GOOGLE_AI_KEY enables Gemini vision, audio, transcription, summary, and detail analysis.
# ============================================================
# GOOGLE_AI_KEY=

# ============================================================
# Optional: browser cookie source for login-walled videos
# ============================================================
# Override the auto-detect order. Default tries:
# Chrome -> Firefox -> Safari -> Edge -> Brave -> Chromium.
# ============================================================
# DEEPSCENE_BROWSER=firefox

# ============================================================
# Optional: server / batch hardening
# ============================================================
# Recommended on shared servers, cron jobs, and queue workers.
# Disables browser cookie autodetect; pass --cookies <file> explicitly
# for login-walled videos.
# ============================================================
# DEEPSCENE_SERVER_MODE=1

# Private cache root. Default:
#   ${XDG_CACHE_HOME:-$HOME/.cache}/deepscene
# The directory must be owned by the service user and must not be a symlink.
# DEEPSCENE_CACHE_DIR=/var/cache/deepscene

# Local .env files are not loaded by default. Enable only for trusted
# development directories.
# DEEPSCENE_LOAD_LOCAL_ENV=1

# Optional batch guardrails.
# DEEPSCENE_MAX_VIDEO_SECONDS=7200
# DEEPSCENE_MAX_DOWNLOAD_MB=1024
# DEEPSCENE_COMMAND_TIMEOUT_SEC=1800

# Optional Gemini model overrides.
# DEEPSCENE_GEMINI_MODEL=gemini-2.5-flash
# DEEPSCENE_GEMINI_VISION_MODEL=gemini-2.5-flash
# DEEPSCENE_GEMINI_AUDIO_MODEL=gemini-2.5-flash
# DEEPSCENE_GEMINI_SYNTHESIS_MODEL=gemini-2.5-flash

# Optional OpenAI-compatible endpoint for final text-only synthesis.
# DEEPSCENE_OPENAI_BASE_URL=https://api.openai.com/v1
# DEEPSCENE_OPENAI_API_KEY=
# DEEPSCENE_OPENAI_MODEL=gpt-4o
