#!/usr/bin/env bash
# deepscene-detail <url-or-video> [--frames N] [--out DIR] [--cookies FILE]
# Builds a detailed reconstruction storyboard as Markdown + JSON.

set -euo pipefail

SELF="${BASH_SOURCE[0]}"
SELF_DIR="$(cd "$(dirname "$SELF")" && pwd)"
ROOT_DIR="$(cd "$SELF_DIR/.." && pwd)"
# shellcheck source=../lib/env.sh
source "$ROOT_DIR/lib/env.sh"

export DEEPSCENE_MODE=detail
export DEEPSCENE_PROG=deepscene-detail
exec python3 "$ROOT_DIR/lib/storyboard.py" "$@"
